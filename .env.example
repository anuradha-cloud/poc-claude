# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ngrok authtoken — https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Atlassian OAuth Bearer token for the remote MCP server.
# How to get it:
#   1. Go to https://developer.atlassian.com/console/myapps/ → create an OAuth 2.0 app
#   2. Add scopes: read:jira-work, read:jira-user, write:jira-work (as needed)
#   3. Complete the Authorization Code + PKCE flow to get an access_token
#   OR use the Atlassian OAuth 2.0 Playground:
#   https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/
ATLASSIAN_TOKEN=your_atlassian_oauth_token_here
ATLASSIAN_CLOUD_ID=bad8f441-6057-xxxx-xxxx-xxxxxx
# GitHub — for auto PR creation
# Token needs: repo scope (create branch, commit, open PR)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo-name          # e.g. myorg/backend-api
GITHUB_BASE_BRANCH=main              # branch PRs will be opened against

# AWS region (used by deploy scripts)
AWS_REGION=us-east-1

https://auth.atlassian.com/authorize?audience=api.atlassian.com&client_id=xxxxxxxxxxx&scope=read%3Ajira-work%20read%3Ajira-user&redirect_uri=http%3A%2F%2Flocalhost%3A3000%2Foauth%2Fcallback&state=${YOUR_USER_BOUND_VALUE}&response_type=code&prompt=consent